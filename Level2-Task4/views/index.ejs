<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration Form</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .navbar { background: rgba(0,0,0,0.3) !important; }
        .card {
            animation: fadeInUp 0.6s ease;
            border: none;
            border-radius: 15px;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .form-control {
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .form-control:focus {
            transform: scale(1.02);
            box-shadow: 0 0 10px rgba(102,126,234,0.5);
        }
        .btn-register {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }
        /* Password strength */
        .strength-bar {
            height: 5px;
            border-radius: 5px;
            transition: all 0.3s ease;
            margin-top: 5px;
        }
        .weak { background: red; width: 33%; }
        .medium { background: orange; width: 66%; }
        .strong { background: green; width: 100%; }

        /* Pages */
        .page { display: none; }
        .page.active { display: block; }

        /* Step indicator */
        .step {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background: #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            transition: all 0.3s ease;
        }
        .step.active { background: #667eea; color: white; }
        .step.done { background: green; color: white; }
        .step-line {
            flex: 1;
            height: 3px;
            background: #ddd;
            transition: all 0.3s ease;
        }
        .step-line.done { background: green; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">🚀 Cognifyz App</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link text-white" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="#">About</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="#">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg p-4">

                    <!-- Step Indicator -->
                    <div class="d-flex align-items-center mb-4 px-2">
                        <div class="step active" id="step1">1</div>
                        <div class="step-line" id="line1"></div>
                        <div class="step" id="step2">2</div>
                        <div class="step-line" id="line2"></div>
                        <div class="step" id="step3">3</div>
                    </div>

                    <% if (errors.length > 0) { %>
                    <div class="alert alert-danger">
                        <% errors.forEach(error => { %>
                            <p class="mb-1">⚠️ <%= error %></p>
                        <% }) %>
                    </div>
                    <% } %>

                    <form action="/submit" method="POST" id="mainForm">

                        <!-- Page 1 - Personal Info -->
                        <div class="page active" id="page1">
                            <h4 class="fw-bold mb-3" style="color:#667eea">Personal Info</h4>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Full Name</label>
                                <input type="text" id="name" name="name" class="form-control" placeholder="Enter your full name" />
                                <div id="nameError" class="text-danger small mt-1"></div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Email Address</label>
                                <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email" />
                                <div id="emailError" class="text-danger small mt-1"></div>
                            </div>
                            <button type="button" class="btn btn-register text-white w-100 py-2 fw-bold" onclick="goToPage2()">
                                Next →
                            </button>
                        </div>

                        <!-- Page 2 - Security -->
                        <div class="page" id="page2">
                            <h4 class="fw-bold mb-3" style="color:#667eea">Security</h4>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Password</label>
                                <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" oninput="checkStrength(this.value)" />
                                <div class="strength-bar" id="strengthBar"></div>
                                <div id="strengthText" class="small mt-1"></div>
                                <div id="passwordError" class="text-danger small mt-1"></div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Confirm Password</label>
                                <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="Confirm password" />
                                <div id="confirmError" class="text-danger small mt-1"></div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary w-50 py-2" onclick="goToPage1()">← Back</button>
                                <button type="button" class="btn btn-register text-white w-50 py-2 fw-bold" onclick="goToPage3()">Next →</button>
                            </div>
                        </div>

                        <!-- Page 3 - Contact -->
                        <div class="page" id="page3">
                            <h4 class="fw-bold mb-3" style="color:#667eea">Contact Info</h4>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Phone Number</label>
                                <input type="tel" id="phone" name="phone" class="form-control" placeholder="Enter phone number" />
                                <div id="phoneError" class="text-danger small mt-1"></div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Address</label>
                                <input type="text" id="address" name="address" class="form-control" placeholder="Enter your address" />
                            </div>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary w-50 py-2" onclick="goToPage2()">← Back</button>
                                <button type="submit" class="btn btn-register text-white w-50 py-2 fw-bold">Register 🚀</button>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Password strength checker
        function checkStrength(password) {
            const bar = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');
            bar.className = 'strength-bar';

            if (password.length === 0) {
                text.textContent = '';
                return;
            }

            const hasUpper = /[A-Z]/.test(password);
            const hasNumber = /[0-9]/.test(password);
            const hasSpecial = /[!@#$%^&*]/.test(password);
            const isLong = password.length >= 8;

            const score = [hasUpper, hasNumber, hasSpecial, isLong].filter(Boolean).length;

            if (score <= 1) {
                bar.classList.add('weak');
                text.textContent = '🔴 Weak password';
                text.style.color = 'red';
            } else if (score <= 3) {
                bar.classList.add('medium');
                text.textContent = '🟠 Medium password';
                text.style.color = 'orange';
            } else {
                bar.classList.add('strong');
                text.textContent = '🟢 Strong password';
                text.style.color = 'green';
            }
        }

        // Page navigation
        function goToPage1() {
            showPage('page1');
            updateSteps(1);
        }

        function goToPage2() {
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();
            let valid = true;

            if (!name) {
                document.getElementById('nameError').textContent = '⚠️ Name is required';
                valid = false;
            } else {
                document.getElementById('nameError').textContent = '';
            }

            if (!email || !email.includes('@')) {
                document.getElementById('emailError').textContent = '⚠️ Valid email is required';
                valid = false;
            } else {
                document.getElementById('emailError').textContent = '';
            }

            if (valid) {
                showPage('page2');
                updateSteps(2);
            }
        }

        function goToPage3() {
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirmPassword').value;
            let valid = true;

            if (password.length < 6) {
                document.getElementById('passwordError').textContent = '⚠️ Password must be at least 6 characters';
                valid = false;
            } else {
                document.getElementById('passwordError').textContent = '';
            }

            if (password !== confirm) {
                document.getElementById('confirmError').textContent = '⚠️ Passwords do not match';
                valid = false;
            } else {
                document.getElementById('confirmError').textContent = '';
            }

            if (valid) {
                showPage('page3');
                updateSteps(3);
            }
        }

        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
        }

        function updateSteps(current) {
            for (let i = 1; i <= 3; i++) {
                const step = document.getElementById('step' + i);
                step.classList.remove('active', 'done');
                if (i < current) step.classList.add('done');
                else if (i === current) step.classList.add('active');
            }
            for (let i = 1; i <= 2; i++) {
                const line = document.getElementById('line' + i);
                line.classList.remove('done');
                if (i < current) line.classList.add('done');
            }
        }
    </script>
</body>
</html>