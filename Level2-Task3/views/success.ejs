<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration Successful</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .card {
            animation: fadeInUp 0.6s ease;
            border: none;
            border-radius: 15px;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .success-icon {
            font-size: 4rem;
            animation: bounce 1s ease infinite;
        }
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .btn-back {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }
        .info-item {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 12px 20px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg p-4 text-center">
                    <div class="success-icon">🎉</div>
                    <h2 class="fw-bold mt-3" style="color: #667eea">Registration Successful!</h2>
                    <p class="text-muted mb-4">Welcome aboard! Here are your details:</p>

                    <div class="text-start">
                        <div class="info-item">
                            <span class="fw-bold">👤 Name:</span> <%= name %>
                        </div>
                        <div class="info-item">
                            <span class="fw-bold">📧 Email:</span> <%= email %>
                        </div>
                        <div class="info-item">
                            <span class="fw-bold">📱 Phone:</span> <%= phone %>
                        </div>
                    </div>

                    <a href="/" class="btn btn-back text-white w-100 py-2 fw-bold mt-4">
                        ← Go Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>